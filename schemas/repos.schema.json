{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hanfour.github.io/multi-repo-agent/schemas/repos.schema.json",
  "title": "MRA Workspace Repos",
  "description": "List of repositories the workspace tracks. Stored at .collab/repos.json.",
  "type": "object",
  "required": ["repos"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "clone"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "clone": { "type": "boolean" },
          "branch": { "type": "string" },
          "description": { "type": "string" },
          "archived": { "type": "boolean" }
        }
      }
    }
  }
}
