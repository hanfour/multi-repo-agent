{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hanfour.github.io/multi-repo-agent/schemas/integration/v1/review-request.schema.json",
  "type": "object",
  "required": ["schema", "protocolVersion", "requestId", "subject", "review"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "io.mra.integration.review-request/v1" },
    "protocolVersion": { "const": "1.0" },
    "requestId": { "type": "string", "minLength": 1 },
    "subject": {
      "type": "object",
      "required": ["checkout", "project", "baseSha", "headSha"],
      "additionalProperties": false,
      "properties": {
        "checkout": { "type": "string", "pattern": "^/" },
        "project": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "pullRequest": { "type": "integer", "minimum": 1 },
        "baseSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
        "headSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }
      }
    },
    "review": {
      "type": "object",
      "required": ["provider", "strategy"],
      "additionalProperties": false,
      "properties": {
        "provider": { "const": "codex" },
        "strategy": { "const": "standard" }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pr": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string" },
            "body": { "type": "string" },
            "updatedAt": { "type": "string" }
          }
        }
      }
    }
  }
}
