{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hanfour.github.io/multi-repo-agent/schemas/integration/v1/review-result.schema.json",
  "type": "object",
  "required": ["schema", "protocolVersion", "requestId", "requestSha256", "subject", "producer", "context", "providers", "analysis", "findings", "blockerLedger", "summary", "errors", "artifactSha256"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "io.mra.integration.review-result/v1" },
    "protocolVersion": { "const": "1.0" },
    "requestId": { "type": "string", "minLength": 1 },
    "requestSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "artifactSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "subject": {
      "type": "object", "required": ["headSha", "baseSha"], "additionalProperties": false,
      "properties": {
        "headSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
        "baseSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }
      }
    },
    "producer": {
      "type": "object", "required": ["product"], "additionalProperties": false,
      "properties": { "product": { "const": "multi-repo-agent" } }
    },
    "context": {
      "type": "object", "required": ["mode", "nativeRepositoryInstructions"], "additionalProperties": false,
      "properties": { "mode": { "const": "sanitized-untrusted" }, "nativeRepositoryInstructions": { "const": false } }
    },
    "providers": {
      "type": "array", "minItems": 1, "maxItems": 1,
      "items": {
        "type": "object", "required": ["provider", "status"], "additionalProperties": false,
        "properties": { "provider": { "const": "codex" }, "status": { "enum": ["complete", "partial", "failed"] } }
      }
    },
    "analysis": {
      "type": "object",
      "required": ["status", "verdict"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["complete", "partial", "failed"] },
        "verdict": { "enum": ["pass", "block", "inconclusive"] }
      }
    },
    "findings": { "type": "array", "items": { "$ref": "#/definitions/finding" } },
    "blockerLedger": { "type": "array", "items": { "$ref": "#/definitions/finding" } },
    "summary": { "type": "string" },
    "errors": { "type": "array" }
  },
  "definitions": {
    "finding": {
      "type": "object", "required": ["path", "line", "severity", "body"],
      "properties": {
        "path": { "type": "string", "minLength": 1 }, "line": { "type": "integer", "minimum": 1 },
        "severity": { "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] }, "body": { "type": "string", "minLength": 1 }
      }
    }
  }
}
